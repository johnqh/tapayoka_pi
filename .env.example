# Transport: 'ble' (default) or 'ws' (local dev without BLE hardware)
TRANSPORT=ble
# Server wallet address (written by vendor app via BLE, or set here)
SERVER_WALLET_ADDRESS=
# GPIO pin for relay control (BCM numbering)
GPIO_PIN=17
# Optional: override BLE adapter address
BLE_ADAPTER=
# Kiosk state directory (default: /var/www/html, use /tmp/tapayoka_kiosk for local dev)
KIOSK_STATE_DIR=/var/www/html
# Kiosk HTTP server port
KIOSK_PORT=8026
